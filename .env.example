# Discord Bot Testing Environment Variables
# Copy this file to .env and fill in your values

# Get these from Discord Developer Portal
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_APP_ID=your-app-id-here
DISCORD_PUBLIC_KEY=your-public-key-here

# Get these from Discord (Enable Developer Mode -> Right-click)
DISCORD_CHANNEL_ID=your-channel-id-here
DISCORD_GUILD_ID=your-guild-id-here

# Worker URL (for local testing)
WORKER_URL=http://localhost:8787
